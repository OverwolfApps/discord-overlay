{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "Discord Overlay",
    "author": "Bluscream, Antigravity",
    "version": "1.0.0",
    "minimum-overwolf-version": "0.170.0",
    "description": "Overlay app for Discord. Powered by OrbolayBridge",
    "icon": "icons/IconMouseOver.png",
    "icon_gray": "icons/IconMouseNormal.png",
    "launcher_icon": "icons/desktop-icon.ico",
    "window_icon": "icons/IconMouseOver.png"
  },
  "permissions": [
    "Hotkeys",
    "GameInfo",
    "Clipboard",
    "DesktopStreaming"
  ],
  "data": {
    "start_window": "background",
    "externally_connectable": {
      "matches": ["http://127.0.0.1", "http://localhost"]
    },
    "extra-objects": {
      "websocket-server-plugin": {
        "file": "plugins/DiscordOverlayWebSocketServer.dll",
        "class": "DiscordOverlay.WebSocketServerPlugin"
      }
    },
    "windows": {
      "background": {
        "file": "windows/background/background.html",
        "background_optimization": true,
        "is_background_page": true
      },
      "settings": {
        "file": "windows/settings/settings.html",
        "desktop_only": true,
        "native_window": true,
        "resizable": false,
        "transparent": true,
        "size": {
          "width": 690,
          "height": 470
        },
        "min_size": {
          "width": 690,
          "height": 470
        }
      },
      "hud": {
        "file": "windows/hud/hud.html",
        "transparent": true,
        "resizable": false,
        "native_window": true,
        "show_in_taskbar": false,
        "topmost": true,
        "size": {
          "width": 260,
          "height": 400
        }
      },
      "dashboard": {
        "file": "windows/dashboard/dashboard.html",
        "transparent": true,
        "resizable": false,
        "native_window": true,
        "show_in_taskbar": false,
        "topmost": true,
        "size": {
          "width": 420,
          "height": 360
        }
      },
      "notifications": {
        "file": "windows/notifications/notifications.html",
        "transparent": true,
        "resizable": false,
        "show_in_taskbar": false,
        "topmost": true,
        "click_through": true,
        "size": {
          "width": 300,
          "height": 500
        }
      }
    },
    "game_targeting": {
      "type": "all"
    }
  }
}