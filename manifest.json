{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "Discord Overlay",
    "author": "Bluscream, Antigravity",
    "version": "1.0.0",
    "minimum-overwolf-version": "0.170.0",
    "description": "Overlay app for Discord. Powered by OrbolayBridge",
    "icon": "icons/IconMouseOver.png",
    "icon_gray": "icons/IconMouseNormal.png",
    "launcher_icon": "icons/desktop-icon.ico",
    "window_icon": "icons/IconMouseOver.png"
  },
  "permissions": [
    "Hotkeys",
    "GameInfo",
    "Clipboard",
    "DesktopStreaming"
  ],
  "data": {
    "start_window": "background",
    "extra-objects": {
      "websocket-server-plugin": {
        "file": "plugins/DiscordOverlayWebSocketServer.dll",
        "class": "DiscordOverlay.WebSocketServerPlugin"
      }
    },
    "hotkeys": {
      "toggle_overlay_interactive": {
        "title": "Toggle Overlay Interaction (Unlock Cursor)",
        "action-type": "custom",
        "default": "Ctrl+BackQuote"
      }
    },
    "windows": {
      "background": {
        "file": "windows/background/background.html",
        "background_optimization": true,
        "is_background_page": true
      },
      "settings": {
        "file": "windows/settings/settings.html",
        "desktop_only": true,
        "native_window": true,
        "resizable": false,
        "transparent": true,
        "size": {
          "width": 690,
          "height": 470
        },
        "min_size": {
          "width": 690,
          "height": 470
        }
      },
      "overlay": {
        "file": "windows/overlay/overlay.html",
        "transparent": true,
        "resizable": false,
        "size": {
          "width": 1920,
          "height": 1080
        }
      },
      "notifications": {
        "file": "windows/notifications/notifications.html",
        "transparent": true,
        "resizable": false,
        "show_in_taskbar": false,
        "topmost": true,
        "click_through": true,
        "size": {
          "width": 300,
          "height": 500
        }
      }
    },
    "game_targeting": {
      "type": "all"
    },
    "developer": {
      "enable_auto_refresh": true,
      "reload_delay": 1000,
      "filter": "*.*"
    }
  }
}